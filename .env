# ============================================
# M-PESA CONFIGURATION
# ============================================
# Your M-Pesa Shortcode (PayBill/Till Number)
MPESA_SHORTCODE=4095377

# M-Pesa Environment (sandbox or production)
# Use 'sandbox' for testing, 'production' for live
MPESA_ENVIRONMENT=sandbox

# M-Pesa API Credentials (Get from Daraja Portal)
# https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_PASSKEY=your_passkey_here

# M-Pesa Callback URL (where Safaricom sends payment confirmation)
MPESA_CALLBACK_URL=https://www.meidriveafrica.com/api/mpesa/callback

# ============================================
# APP CONFIGURATION
# ============================================
# App URL (for callbacks and CORS)
APP_URL=https://www.meidriveafrica.com
APP_URL_LOCAL=http://localhost:5173
APP_URL_RENDER=https://meidriveafrica.onrender.com
APP_URL_VERCEL=https://meidriveafrica.vercel.app

# Node Environment
NODE_ENV=production

# Server Port
PORT=5000

# ============================================
# ADMIN CREDENTIALS
# ============================================
ADMIN_EMAIL=admin@meidriveafrica.com
ADMIN_PASSWORD=Admin@2026

# ============================================
# SECURITY
# ============================================
# Session timeout (in seconds)
SESSION_TIMEOUT=3600

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# CORS allowed origins
CORS_ORIGINS=https://www.meidriveafrica.com,https://meidriveafrica.vercel.app,https://meidriveafrica.onrender.com,http://localhost:5173,http://localhost:8000

